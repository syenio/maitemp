MONGODB_URI=mongodb://localhost:27017/maid-booking
JWT_SECRET=your-jwt-secret-key
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# NextAuth Configuration
NEXTAUTH_SECRET=your-nextauth-secret-key
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Hardcoded Admin Credentials
ADMIN_EMAIL=admin@maidsforcare.com
ADMIN_PASSWORD=Admin@123456
ADMIN_SECRET_KEY=super-secret-admin-key-2024

# Cloudflare R2 Configuration
# Get these values from your Cloudflare dashboard after creating an R2 bucket and API token
# Endpoint format: https://your-account-id.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=maidease-uploads
# Optional: Custom domain for public access (leave empty to use R2 endpoint)
R2_PUBLIC_URL= 